---
import { type Locale, getLocalePath, locales } from '../i18n/translations';
import { switchLangPath } from '../i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

const langLabels: Record<Locale, string> = { zh: '中文', en: 'English', ja: '日本語' };
---

<nav id="site-nav">
  <a href={getLocalePath(locale)} class="logo">mmwuzhi.dev</a>
  <div class="nav-right">
    <ul>
      <li><a href={getLocalePath(locale, 'blog')}>Blog</a></li>
      <li><a href={getLocalePath(locale, 'garden')}>Garden</a></li>
      <li><a href={getLocalePath(locale, 'now')}>Now</a></li>
      <li><a href={getLocalePath(locale, 'about')}>About</a></li>
    </ul>
    <button class="search-btn" id="search-open" aria-label="Search">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
    </button>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
      <span class="icon-light">☀️</span>
      <span class="icon-dark">🌙</span>
    </button>
    <div class="lang-select">
      <select
        aria-label="Language"
        onchange="var l=this.value.startsWith('/en')?'en':this.value.startsWith('/ja')?'ja':'zh';localStorage.setItem('preferred-lang',l);location.href=this.value"
      >
        {locales.map((l) => (
          <option value={switchLangPath(locale, l, currentPath)} selected={l === locale}>
            {langLabels[l]}
          </option>
        ))}
      </select>
      <svg class="arrow" aria-hidden="true" width="10" height="6" viewBox="0 0 10 6" fill="none">
        <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <a href={getLocalePath(locale, 'blog')}>Blog</a>
    <a href={getLocalePath(locale, 'garden')}>Garden</a>
    <a href={getLocalePath(locale, 'now')}>Now</a>
    <a href={getLocalePath(locale, 'about')}>About</a>
  </div>
</nav>

<style>
  nav {
    padding: 1.4rem var(--page-x);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  .logo {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-family: var(--sans);
    color: var(--text2);
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .logo:hover { color: var(--accent); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  ul {
    list-style: none;
    display: flex;
    gap: 1.25rem;
  }

  ul a {
    text-decoration: none;
    color: var(--text2);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  ul a:hover { color: var(--accent); }

  .lang-select {
    position: relative;
    flex-shrink: 0;
  }

  select {
    appearance: none;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text2);
    font-family: var(--sans);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    padding: 0.28rem 1.75rem 0.28rem 0.65rem;
    cursor: pointer;
    outline: none;
    min-width: 5.5rem;
    transition: border-color 0.15s, color 0.15s;
  }

  select:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .search-btn {
    display: flex;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text2);
    flex-shrink: 0;
    padding: 0;
    transition: color 0.15s;
  }

  .search-btn:hover { color: var(--accent); }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--text2);
    padding: 0.2rem;
    line-height: 1;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .theme-toggle:hover { color: var(--accent); }

  .icon-dark { display: none; }
  :global([data-theme='dark']) .icon-light { display: none; }
  :global([data-theme='dark']) .icon-dark { display: inline; }

  .arrow {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text2);
    pointer-events: none;
    display: block;
  }

  /* Hamburger */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.2rem;
    flex-shrink: 0;
  }

  .bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text2);
    border-radius: 1px;
    transition: background 0.15s;
  }

  .menu-toggle:hover .bar { background: var(--accent); }

  /* Mobile dropdown */
  .mobile-nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 0.25rem var(--page-x) 0.75rem;
    flex-direction: column;
    z-index: 10;
  }

  .mobile-nav.open { display: flex; }

  .mobile-nav a {
    display: block;
    text-decoration: none;
    color: var(--text2);
    font-size: 0.9rem;
    font-family: var(--sans);
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s;
  }

  .mobile-nav a:last-child { border-bottom: none; }
  .mobile-nav a:hover { color: var(--accent); }

  @media (max-width: 640px) {
    ul { display: none; }
    .menu-toggle { display: flex; }
    .nav-right { gap: 0.75rem; }
  }
</style>

<script>
  // Preserve data-theme across View Transitions
  document.addEventListener('astro:before-swap', (e) => {
    const theme = document.documentElement.getAttribute('data-theme');
    if (theme) (e as any).newDocument.documentElement.setAttribute('data-theme', theme);
  });

  // Close mobile menu on outside click (registered once at module level)
  document.addEventListener('click', (e) => {
    const mobileNav = document.getElementById('mobile-nav');
    const menuBtn = document.getElementById('menu-toggle');
    if (
      mobileNav?.classList.contains('open') &&
      !mobileNav.contains(e.target as Node) &&
      !menuBtn?.contains(e.target as Node)
    ) {
      mobileNav.classList.remove('open');
      mobileNav.setAttribute('aria-hidden', 'true');
      menuBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  function initNav() {
    // Theme toggle
    const btn = document.getElementById('theme-toggle');
    if (btn) {
      btn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        const giscusFrame = document.querySelector<HTMLIFrameElement>('.giscus-frame');
        if (giscusFrame) {
          giscusFrame.contentWindow?.postMessage(
            { giscus: { setConfig: { theme: next === 'dark' ? 'noborder_dark' : 'noborder_light' } } },
            'https://giscus.app'
          );
        }
      });
    }

    // Hamburger toggle
    const menuBtn = document.getElementById('menu-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    if (menuBtn && mobileNav) {
      menuBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = mobileNav.classList.toggle('open');
        menuBtn.setAttribute('aria-expanded', String(isOpen));
        mobileNav.setAttribute('aria-hidden', String(!isOpen));
      });
    }
  }

  function syncLangSelect() {
    const select = document.querySelector<HTMLSelectElement>('.lang-select select');
    if (!select) return;
    const path = location.pathname;
    const lang = path.startsWith('/en') ? 'en' : path.startsWith('/ja') ? 'ja' : 'zh';
    for (const opt of select.options) {
      const val = opt.value;
      const optLang = val.startsWith('/en') ? 'en' : val.startsWith('/ja') ? 'ja' : 'zh';
      if (optLang === lang) { select.value = val; break; }
    }
  }

  document.addEventListener('astro:page-load', initNav);
  window.addEventListener('pageshow', syncLangSelect);
</script>
