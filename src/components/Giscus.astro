---
import type { Locale } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const langMap: Record<Locale, string> = {
  zh: 'zh-CN',
  en: 'en',
  ja: 'ja',
};
---

<div class="giscus-wrap" id="giscus-wrap">
  <script is:inline define:vars={{ lang: langMap[locale] }}>
    (function () {
      var theme = document.documentElement.getAttribute('data-theme') === 'dark'
        ? 'noborder_dark'
        : 'noborder_light';
      var s = document.createElement('script');
      s.src = 'https://giscus.app/client.js';
      s.dataset.repo = 'mmwuzhi/mmwuzhi.github.io';
      s.dataset.repoId = 'MDEwOlJlcG9zaXRvcnkyMTAzMTU5Njk=';
      s.dataset.category = 'Announcements';
      s.dataset.categoryId = 'DIC_kwDODIkqwc4C7Yus';
      s.dataset.mapping = 'pathname';
      s.dataset.strict = '0';
      s.dataset.reactionsEnabled = '1';
      s.dataset.emitMetadata = '0';
      s.dataset.inputPosition = 'bottom';
      s.dataset.theme = theme;
      s.dataset.lang = lang;
      s.crossOrigin = 'anonymous';
      s.async = true;
      document.getElementById('giscus-wrap').appendChild(s);
    })();
  </script>
</div>

<style>
  .giscus-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem var(--page-x) 5rem;
    border-top: 1px solid var(--border);
  }
</style>
