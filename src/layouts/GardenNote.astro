---
import BaseLayout from './BaseLayout.astro';
import { useTranslations, getLocalePath, type Locale } from '../i18n/translations';
import type { Backlink } from '../utils/backlinks';

interface Props {
  locale: Locale;
  title: string;
  updated: Date;
  stage: 'seedling' | 'budding' | 'evergreen';
  tags: string[];
  backlinks: Backlink[];
}

const { locale, title, updated, stage, tags, backlinks } = Astro.props;
const tr = useTranslations(locale);

const stageIcon = { seedling: '🌱', budding: '🌿', evergreen: '🌲' };
const updatedStr = updated.toLocaleDateString(
  locale === 'zh' ? 'zh-CN' : locale === 'ja' ? 'ja-JP' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
---

<BaseLayout {locale} {title}>
  <article class="note" lang={locale}>
    <div class="header">
      <a href={getLocalePath(locale, 'garden')} class="back">← Garden</a>
      <div class="rule"></div>
      <h1>{title}</h1>
      <div class="meta">
        <span class="stage">{stageIcon[stage]} {tr.garden.stages[stage]}</span>
        <span class="sep">·</span>
        <span>{tr.garden.updated} {updatedStr}</span>
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>

    <div class="prose">
      <slot />
    </div>

    {backlinks.length > 0 && (
      <div class="backlinks">
        <div class="backlinks-label">{tr.garden.backlinks}</div>
        <ul>
          {backlinks.map((bl) => (
            <li>
              <a href={getLocalePath(locale, `garden/${bl.postSlug}`)}>{bl.title}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .note {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem var(--page-x) 6rem;
  }

  .back {
    display: inline-block; font-size: 0.8rem; color: var(--text2);
    text-decoration: none; margin-bottom: 2.5rem; transition: color 0.2s;
  }
  .back:hover { color: var(--accent); }

  .rule { width: 28px; height: 2px; background: var(--accent); margin-bottom: 1.5rem; }

  h1 { font-size: 2rem; line-height: 1.3; margin-bottom: 0.75rem; }

  .meta {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem;
    font-size: 0.78rem; color: var(--text2); font-family: var(--sans);
    margin-bottom: 3rem;
  }

  .sep { opacity: 0.4; }

  .stage { color: var(--text2); }

  .tag {
    background: var(--border); border-radius: 2px;
    padding: 0.1rem 0.5rem; font-size: 0.7rem; letter-spacing: 0.05em;
  }

  .backlinks {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .backlinks-label {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--text2); font-family: var(--sans); margin-bottom: 0.75rem;
  }

  .backlinks ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }

  .backlinks a {
    font-size: 0.9rem; color: var(--text2); text-decoration: none; transition: color 0.15s;
  }
  .backlinks a:hover { color: var(--accent); }
</style>
