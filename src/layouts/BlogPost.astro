---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import { useTranslations, getLocalePath, type Locale } from '../i18n/translations';
import { estimateReadingTime } from '../utils/readingTime';
import type { PostStub } from '../utils/adjacentPosts';

interface Props {
  locale: Locale;
  title: string;
  date: Date;
  category: string;
  body: string;
  prev?: PostStub | null;
  next?: PostStub | null;
}

const { locale, title, date, category, body, prev = null, next = null } = Astro.props;
const readingTime = estimateReadingTime(body, locale);
const tr = useTranslations(locale);

const dateStr = date.toLocaleDateString(
  locale === 'zh' ? 'zh-CN' : locale === 'ja' ? 'ja-JP' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
---

<BaseLayout {locale} {title} description={`${category} · ${dateStr}`}>
  <article class="post" lang={locale}>
    <div class="header">
      <a href={getLocalePath(locale, 'blog')} class="back">{tr.posts.back}</a>
      <div class="rule"></div>
      <h1>{title}</h1>
      <div class="meta">{dateStr} · {category} · {readingTime}</div>
    </div>
    <div class="prose">
      <slot />
    </div>
  </article>

  {(prev || next) && (
    <nav class="adjacent">
      <div class="adjacent-inner">
        {next && (
          <a href={getLocalePath(locale, `blog/${next.postSlug}`)} class="adj-link adj-next">
            <span class="adj-label">← Older</span>
            <span class="adj-title">{next.title}</span>
          </a>
        )}
        {prev && (
          <a href={getLocalePath(locale, `blog/${prev.postSlug}`)} class="adj-link adj-prev">
            <span class="adj-label">Newer →</span>
            <span class="adj-title">{prev.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}

  <Giscus {locale} />
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem var(--page-x) 6rem;
  }

  .back {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--text2);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }

  .back:hover { color: var(--accent); }

  .rule {
    width: 28px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .meta {
    font-size: 0.78rem;
    color: var(--text2);
    letter-spacing: 0.05em;
    margin-bottom: 3rem;
    font-family: var(--sans);
  }

  .adjacent {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0 3rem;
  }

  .adjacent-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--page-x);
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  .adj-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
    max-width: 46%;
  }

  .adj-prev { align-items: flex-end; margin-left: auto; }

  .adj-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text2);
    font-family: var(--sans);
  }

  .adj-title {
    font-size: 0.9rem;
    color: var(--text);
    transition: color 0.15s;
    line-height: 1.4;
  }

  .adj-link:hover .adj-title { color: var(--accent); }
</style>
