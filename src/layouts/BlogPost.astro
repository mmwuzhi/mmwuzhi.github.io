---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import { useTranslations, getLocalePath, type Locale } from '../i18n/translations';
import { estimateReadingTime } from '../utils/readingTime';
import { buildToc } from '../utils/toc';
import type { PostStub } from '../utils/adjacentPosts';

interface Props {
  locale: Locale;
  title: string;
  date: Date;
  category: string;
  body: string;
  prev?: PostStub | null;
  next?: PostStub | null;
  headings?: { depth: number; slug: string; text: string }[];
}

const { locale, title, date, category, body, prev = null, next = null, headings = [] } = Astro.props;
const toc = buildToc(headings);
const readingTime = estimateReadingTime(body, locale);
const tr = useTranslations(locale);

const dateStr = date.toLocaleDateString(
  locale === 'zh' ? 'zh-CN' : locale === 'ja' ? 'ja-JP' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
---

<BaseLayout {locale} {title} description={`${category} · ${dateStr}`}>
  <article class="post" lang={locale}>
    <div class="header">
      <a href={getLocalePath(locale, 'blog')} class="back">{tr.posts.back}</a>
      <div class="rule"></div>
      <h1>{title}</h1>
      <div class="meta">{dateStr} · {category} · {readingTime}</div>
    </div>
    {toc.length >= 3 && (
      <nav class="toc" aria-label="Table of contents">
        <div class="toc-title">Contents</div>
        <ol>
          {toc.map((item) => (
            <li class={item.depth === 3 ? 'toc-sub' : ''}>
              <a href={`#${item.slug}`}>{item.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}
    <div class="prose">
      <slot />
    </div>
  </article>

  {(prev || next) && (
    <nav class="adjacent">
      <div class="adjacent-inner">
        {next && (
          <a href={getLocalePath(locale, `blog/${next.postSlug}`)} class="adj-link adj-next">
            <span class="adj-label">← Older</span>
            <span class="adj-title">{next.title}</span>
          </a>
        )}
        {prev && (
          <a href={getLocalePath(locale, `blog/${prev.postSlug}`)} class="adj-link adj-prev">
            <span class="adj-label">Newer →</span>
            <span class="adj-title">{prev.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}

  <Giscus {locale} />
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem var(--page-x) 6rem;
  }

  .back {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--text2);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }

  .back:hover { color: var(--accent); }

  .rule {
    width: 28px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .meta {
    font-size: 0.78rem;
    color: var(--text2);
    letter-spacing: 0.05em;
    margin-bottom: 3rem;
    font-family: var(--sans);
  }

  .toc {
    margin-bottom: 3rem;
    padding: 1.25rem 1.5rem;
    border-left: 2px solid var(--accent);
    background: none;
  }

  .toc-title {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-family: var(--sans);
    color: var(--text2);
    margin-bottom: 0.75rem;
  }

  .toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .toc li a {
    font-size: 0.875rem;
    color: var(--text2);
    text-decoration: none;
    transition: color 0.15s;
    line-height: 1.4;
  }

  .toc li a:hover { color: var(--accent); }

  .toc li.toc-sub a {
    font-size: 0.8rem;
    padding-left: 1rem;
  }

  .adjacent {
    border-top: 1px solid var(--border);
    padding: 2.5rem 0 3rem;
  }

  .adjacent-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--page-x);
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  .adj-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
    max-width: 46%;
  }

  .adj-prev { align-items: flex-end; margin-left: auto; }

  .adj-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text2);
    font-family: var(--sans);
  }

  .adj-title {
    font-size: 0.9rem;
    color: var(--text);
    transition: color 0.15s;
    line-height: 1.4;
  }

  .adj-link:hover .adj-title { color: var(--accent); }

  .prose pre { position: relative; }

  .prose h2, .prose h3, .prose h4 { scroll-margin-top: 5rem; }

  .heading-anchor {
    margin-left: 0.35em;
    color: var(--border);
    text-decoration: none;
    font-weight: normal;
    font-style: normal;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s;
    font-size: 0.8em;
    user-select: none;
  }

  .prose h2:hover .heading-anchor,
  .prose h3:hover .heading-anchor,
  .prose h4:hover .heading-anchor { opacity: 1; }

  .heading-anchor:hover { color: var(--accent); }

  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.18rem 0.5rem;
    font-size: 0.68rem;
    font-family: var(--sans);
    color: var(--text2);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s;
    line-height: 1.5;
  }

  .prose pre:hover .copy-btn { opacity: 1; }
  .copy-btn:hover { color: var(--accent); }
</style>

<script>
  function attachHeadingAnchors() {
    document.querySelectorAll('.prose h2, .prose h3, .prose h4').forEach((h) => {
      if (!h.id || h.querySelector('.heading-anchor')) return;
      const a = document.createElement('a');
      a.className = 'heading-anchor';
      a.href = `#${h.id}`;
      a.setAttribute('aria-label', 'Link to section');
      a.textContent = '#';
      h.appendChild(a);
    });
  }

  function attachCopyButtons() {
    document.querySelectorAll('.prose pre').forEach((pre) => {
      if (pre.querySelector('.copy-btn')) return;
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'Copy';
      btn.addEventListener('click', () => {
        const text = pre.querySelector('code')?.textContent ?? '';
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        });
      });
      pre.appendChild(btn);
    });
  }
  document.addEventListener('astro:page-load', () => {
    attachHeadingAnchors();
    attachCopyButtons();
  });
</script>
