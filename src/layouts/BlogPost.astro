---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import { useTranslations, getLocalePath, type Locale } from '../i18n/translations';

interface Props {
  locale: Locale;
  title: string;
  date: Date;
  category: string;
}

const { locale, title, date, category } = Astro.props;
const tr = useTranslations(locale);

const dateStr = date.toLocaleDateString(
  locale === 'zh' ? 'zh-CN' : locale === 'ja' ? 'ja-JP' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
---

<BaseLayout {locale} {title} description={`${category} · ${dateStr}`}>
  <article class="post" lang={locale}>
    <div class="header">
      <a href={getLocalePath(locale, 'blog')} class="back">{tr.posts.back}</a>
      <div class="rule"></div>
      <h1>{title}</h1>
      <div class="meta">{dateStr} · {category}</div>
    </div>
    <div class="prose">
      <slot />
    </div>
  </article>
  <Giscus {locale} />
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem var(--page-x) 6rem;
  }

  .back {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--text2);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }

  .back:hover { color: var(--accent); }

  .rule {
    width: 28px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .meta {
    font-size: 0.78rem;
    color: var(--text2);
    letter-spacing: 0.05em;
    margin-bottom: 3rem;
    font-family: var(--sans);
  }
</style>
