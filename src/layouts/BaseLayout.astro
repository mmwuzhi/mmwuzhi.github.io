---
import Nav from '../components/Nav.astro';
import { type Locale } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title = '余白', description = '' } = Astro.props;
const currentPath = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" hreflang="zh" href="https://mmwuzhi.dev/" />
    <link rel="alternate" hreflang="en" href="https://mmwuzhi.dev/en/" />
    <link rel="alternate" hreflang="ja" href="https://mmwuzhi.dev/ja/" />
  </head>
  <body>
    <Nav locale={locale} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <footer>
      <span>mmwuzhi.dev</span>
      <div class="footer-links">
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>
  </body>
</html>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 1.75rem var(--page-x);
    display: flex;
    justify-content: space-between;
    font-size: 0.78rem;
    color: var(--text2);
  }

  .footer-links { display: flex; gap: 1.5rem; }

  .footer-links a {
    color: var(--text2);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover { color: var(--accent); }
</style>
