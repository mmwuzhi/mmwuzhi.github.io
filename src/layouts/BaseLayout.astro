---
import Nav from '../components/Nav.astro';
import { ClientRouter } from 'astro:transitions';
import { type Locale } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title = 'Lacuna', description = '' } = Astro.props;
const currentPath = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <ClientRouter />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="Lacuna" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="alternate" hreflang="zh" href="https://mmwuzhi.dev/" />
    <link rel="alternate" hreflang="en" href="https://mmwuzhi.dev/en/" />
    <link rel="alternate" hreflang="ja" href="https://mmwuzhi.dev/ja/" />
    <script is:inline>
      (function () {
        var s = localStorage.getItem('theme');
        var d = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-theme', s || (d ? 'dark' : 'light'));
      })();
    </script>
    <slot name="head" />
    <script is:inline>
      (function () {
        var path = location.pathname;
        var isHome = path === '/' || /^\/(en|ja)\/?$/.test(path);
        if (!isHome) return;
        var stored = localStorage.getItem('preferred-lang');
        var browser = (navigator.language || 'zh').split('-')[0];
        var lang = stored || (browser === 'en' ? 'en' : browser === 'ja' ? 'ja' : 'zh');
        var current = path.startsWith('/en') ? 'en' : path.startsWith('/ja') ? 'ja' : 'zh';
        if (lang !== current) {
          location.replace(lang === 'en' ? '/en/' : lang === 'ja' ? '/ja/' : '/');
        }
      })();
    </script>
  </head>
  <body>
    <Nav locale={locale} currentPath={currentPath} />
    <main data-pagefind-body>
      <slot />
    </main>
    <footer data-pagefind-ignore>
      <div class="footer-links">
        <a href="/rss.xml">RSS</a>
        <a href="https://github.com/mmwuzhi" target="_blank" rel="noopener">GitHub</a>
      </div>
    </footer>

    <dialog id="search-modal" aria-label="Search" data-pagefind-ignore>
      <div class="search-inner">
        <button class="search-close" id="search-close" aria-label="Close search">✕</button>
        <div id="search-ui"></div>
      </div>
    </dialog>
  </body>
</html>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 1.75rem var(--page-x);
    font-size: 0.78rem;
    color: var(--text2);
  }

  .footer-links { display: flex; gap: 1.5rem; }

  .footer-links a {
    color: var(--text2);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover { color: var(--accent); }

  /* dialog hidden by default; only show when open */
  dialog {
    border: none;
    border-radius: 6px;
    background: var(--bg);
    color: var(--text);
    padding: 0;
    width: min(640px, 92vw);
    max-height: 80vh;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
    margin: 8vh auto auto;
  }

  dialog[open] {
    display: flex;
    flex-direction: column;
  }

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(2px);
  }

  .search-inner {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem 1.5rem;
    overflow-y: auto;
  }

  .search-close {
    align-self: flex-end;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--text2);
    padding: 0.1rem 0.25rem;
    line-height: 1;
    margin-bottom: 0.75rem;
    transition: color 0.15s;
  }

  .search-close:hover { color: var(--accent); }
</style>

<script>
  const translations: Record<string, Record<string, string>> = {
    zh: {
      placeholder: '搜索文章和笔记…',
      zero_results: '没有找到「[SEARCH_TERM]」的相关内容',
      many_results: '「[SEARCH_TERM]」共 [COUNT] 条结果',
      one_result: '「[SEARCH_TERM]」共 1 条结果',
      searching: '正在搜索「[SEARCH_TERM]」…',
    },
    en: {
      placeholder: 'Search posts and notes…',
      zero_results: 'No results for "[SEARCH_TERM]"',
      many_results: '[COUNT] results for "[SEARCH_TERM]"',
      one_result: '1 result for "[SEARCH_TERM]"',
      searching: 'Searching for "[SEARCH_TERM]"…',
    },
    ja: {
      placeholder: '記事やノートを検索…',
      zero_results: '「[SEARCH_TERM]」の検索結果はありません',
      many_results: '「[SEARCH_TERM]」の検索結果：[COUNT]件',
      one_result: '「[SEARCH_TERM]」の検索結果：1件',
      searching: '「[SEARCH_TERM]」を検索中…',
    },
  };

  // Resolved once the pagefind script is loaded; null until first open
  let pagefindScriptPromise: Promise<void> | null = null;
  let pagefindUIReady = false;

  function loadPagefindScript(): Promise<void> {
    if (pagefindScriptPromise) return pagefindScriptPromise;
    pagefindScriptPromise = new Promise<void>((resolve, reject) => {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);

      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = () => resolve();
      script.onerror = () => reject(new Error('Failed to load pagefind-ui.js'));
      document.head.appendChild(script);
    });
    return pagefindScriptPromise;
  }

  function initPagefindUI() {
    if (pagefindUIReady) return;
    pagefindUIReady = true;
    const path = location.pathname;
    const locale = path.startsWith('/en') ? 'en' : path.startsWith('/ja') ? 'ja' : 'zh';
    // @ts-ignore
    new PagefindUI({
      element: '#search-ui',
      showImages: false,
      resetStyles: false,
      translations: translations[locale],
    });
  }

  async function openSearch() {
    const modal = document.getElementById('search-modal') as HTMLDialogElement | null;
    if (!modal) return;
    try {
      await loadPagefindScript();
    } catch (e) {
      console.error(e);
      return;
    }
    // Show modal first so #search-ui is visible before PagefindUI renders into it
    modal.showModal();
    initPagefindUI();
    setTimeout(() => modal.querySelector<HTMLInputElement>('input')?.focus(), 50);
  }

  function closeSearch() {
    (document.getElementById('search-modal') as HTMLDialogElement | null)?.close();
  }

  // Backdrop click closes modal
  document.getElementById('search-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeSearch();
  });

  // Wire up buttons on each navigation (DOM may be re-rendered)
  document.addEventListener('astro:page-load', () => {
    document.getElementById('search-open')?.addEventListener('click', openSearch);
    document.getElementById('search-close')?.addEventListener('click', closeSearch);
  });
</script>
