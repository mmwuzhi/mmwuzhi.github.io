---
import Nav from '../components/Nav.astro';
import { type Locale } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title = '余白', description = '' } = Astro.props;
const currentPath = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="余白" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="alternate" hreflang="zh" href="https://mmwuzhi.dev/" />
    <link rel="alternate" hreflang="en" href="https://mmwuzhi.dev/en/" />
    <link rel="alternate" hreflang="ja" href="https://mmwuzhi.dev/ja/" />
    <script is:inline>
      (function () {
        var s = localStorage.getItem('theme');
        var d = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-theme', s || (d ? 'dark' : 'light'));
      })();
    </script>
    <script is:inline>
      (function () {
        var path = location.pathname;
        var isHome = path === '/' || /^\/(en|ja)\/?$/.test(path);
        if (!isHome) return;
        var stored = localStorage.getItem('preferred-lang');
        var browser = (navigator.language || 'zh').split('-')[0];
        var lang = stored || (browser === 'en' ? 'en' : browser === 'ja' ? 'ja' : 'zh');
        var current = path.startsWith('/en') ? 'en' : path.startsWith('/ja') ? 'ja' : 'zh';
        if (lang !== current) {
          location.replace(lang === 'en' ? '/en/' : lang === 'ja' ? '/ja/' : '/');
        }
      })();
    </script>
  </head>
  <body>
    <Nav locale={locale} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-links">
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>
  </body>
</html>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 1.75rem var(--page-x);
    font-size: 0.78rem;
    color: var(--text2);
  }

  .footer-links { display: flex; gap: 1.5rem; }

  .footer-links a {
    color: var(--text2);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover { color: var(--accent); }
</style>
