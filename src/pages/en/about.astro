---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout locale="en" title="About — Lacuna">
  <div class="page" lang="en">
    <div class="rule"></div>
    <h1>About</h1>
    <div class="prose">
      <p>I'm a developer. I note down thoughts and technical tidbits here when I can.</p>
      <p>No fixed theme — just things worth keeping.</p>
      <p>
        GitHub: <a href="https://github.com/mmwuzhi" target="_blank" rel="noopener">mmwuzhi</a>
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem var(--page-x) 6rem;
  }

  .rule {
    width: 28px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 2.5rem;
  }
</style>
