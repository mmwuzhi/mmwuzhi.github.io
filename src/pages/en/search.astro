---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout locale="en" title="Search — Lacuna">
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
  </Fragment>
  <div class="page" data-pagefind-ignore>
    <div class="rule"></div>
    <h1>Search</h1>
    <div id="search"></div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const el = document.getElementById('search');
    if (!el) return;
    // @ts-ignore
    new PagefindUI({ element: '#search', showImages: false, resetStyles: false });
  });
</script>

<style>
  .page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem var(--page-x) 6rem;
  }

  .rule { width: 28px; height: 2px; background: var(--accent); margin-bottom: 2rem; }

  h1 { font-size: 1.5rem; margin-bottom: 2rem; }

  #search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-font: var(--sans);
  }
</style>
