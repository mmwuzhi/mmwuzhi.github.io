---
import { type Locale } from '../i18n/translations';

interface Props {
  title: string;
  date: Date;
  category: string;
  href: string;
  locale: Locale;
}

const { title, date, category, href, locale } = Astro.props;

const dateStr = date.toLocaleDateString(
  locale === 'zh' ? 'zh-CN' : locale === 'ja' ? 'ja-JP' : 'en-US',
  { year: 'numeric', month: '2-digit' }
);
---

<a href={href} class="post-item" lang={locale}>
  <div class="meta">{dateStr} · {category}</div>
  <div class="title">{title}</div>
</a>

<style>
  .post-item {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1rem 0 1rem 1.25rem;
    border-left: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .post-item:hover { border-left-color: var(--accent); }
  .post-item:hover .title { color: var(--accent); }

  .meta {
    font-size: 0.72rem;
    color: var(--text2);
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
    font-family: var(--sans);
  }

  /* Title typography follows language */
  .title {
    line-height: 1.4;
    transition: color 0.2s;
  }

  :lang(zh) .title {
    font-family: var(--serif);
    font-size: 1.05rem;
  }

  :lang(en) .title {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 0.975rem;
  }

  :lang(ja) .title {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 0.975rem;
  }
</style>
